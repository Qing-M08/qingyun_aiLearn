# 应用
APP_NAME=qingyun-zhixue
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-random-64-chars

# 数据库（config.py 基于以下字段动态拼接 DATABASE_URL，密码从 secrets 读取）
DATABASE_USER=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=qingyun
DATABASE_POOL_SIZE=20

# Redis（config.py 基于以下字段动态拼接 REDIS_URL，密码从 secrets 读取）
REDIS_HOST=localhost
REDIS_PORT=6379

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=masterKey_dev

# JWT
JWT_SECRET_KEY=change-me-to-random-64-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 嵌入模型
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# 搜索API
BING_SEARCH_API_KEY=

# 对象存储
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=qingyun-zhixue
OSS_ENDPOINT=

# Celery（config.py 基于 REDIS_HOST/REDIS_PORT 动态拼接 URL，密码从 secrets 读取）
# 本地开发时 Redis 无密码，自动生成 redis://localhost:6379/1 和 /2

# Agent编排
AGENT_MAX_STEPS=6
AGENT_TOKEN_BUDGET=4000

# Agent 对话历史
AGENT_MAX_CONVERSATION_TURNS=10
AGENT_AUTO_TITLE=true

# 搜索增强
SEARCH_HIGHLIGHT_ENABLED=true
SEARCH_SEMANTIC_WEIGHT=0.3
SEARCH_MEILISEARCH_TIMEOUT=5000

# 用户记忆
MEMORY_HABIT_SUMMARY_MAX_TOKENS=300
MEMORY_RECALL_MAX_TOKENS=800
MEMORY_INDEX_CACHE_TTL=3600

# 取消令牌
AGENT_CANCEL_TTL=300
